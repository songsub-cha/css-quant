# Copy to .env and adjust for local use. Never commit the real .env (see
# repo .gitignore).

# Postgres connection string. Any of postgres://, postgresql://,
# postgresql+asyncpg://, postgresql+psycopg2:// are accepted and
# auto-rewritten to the psycopg 3 driver at load time (SoT B5.1 / ADR 0005 —
# asyncpg is banned after a real SSL incompatibility with managed Postgres).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quantpilot

# Redis connection string (Arq worker + cache, SoT B5.4). This default targets
# a locally-run redis (e.g. `uv run uvicorn`/`uv run arq` outside Docker). Inside
# docker-compose.dev.yml this is overridden to redis://redis:6379/0 — containers
# reach Redis by service name, not localhost.
REDIS_URL=redis://localhost:6379/0

# Cookie Secure flag (SoT B4.6 / D2) — its own env var, deliberately not
# derived from ENVIRONMENT (predecessor-repo trap: "production" + HTTP-only
# IP access locked the owner out of login). Settings.cookie_secure has NO
# Python-level default, so this must be set explicitly for every deployment:
#   true  = Tailscale HTTPS (SoT D3 primary access path)
#   false = LAN HTTP fallback (PWA/web push/Google OAuth unavailable)
# If you have a pre-existing local .env from before this line was added,
# you must add it by hand — the app (and `uv run pytest`) will fail to boot
# without it.
COOKIE_SECURE=false

# Signup gate (SoT D2). Stays false except for the one-time owner bootstrap
# (flip true, create the owner account, flip back to false).
SIGNUP_ENABLED=false
