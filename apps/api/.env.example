# Copy to .env and adjust for local use. Never commit the real .env (see
# repo .gitignore).

# Postgres connection string. Any of postgres://, postgresql://,
# postgresql+asyncpg://, postgresql+psycopg2:// are accepted and
# auto-rewritten to the psycopg 3 driver at load time (SoT B5.1 / ADR 0005 —
# asyncpg is banned after a real SSL incompatibility with managed Postgres).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quantpilot

# Redis connection string (Arq worker + cache, SoT B5.4). This default targets
# a locally-run redis (e.g. `uv run uvicorn`/`uv run arq` outside Docker). Inside
# docker-compose.dev.yml this is overridden to redis://redis:6379/0 — containers
# reach Redis by service name, not localhost.
REDIS_URL=redis://localhost:6379/0
